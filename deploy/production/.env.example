COMPOSE_PROJECT_NAME=wukongim_prod
# Confirm all public endpoint values below before rollout.
# For this target server they default to 42.194.218.158, but update them together
# if you move to a domain name, reverse proxy, or different public ports.
EXTERNAL_IP=42.194.218.158
PUBLIC_DOMAIN=wemx.cc
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443
PUBLIC_WK_API_PORT=5001
PUBLIC_WK_API_BIND=127.0.0.1:5001
WUKONGIM_IMAGE=wukongim/wukongim:v2.2.4-redacted-20260503
# Advertise the HTTPS edge in WuKongIM route metadata; do not advertise the
# loopback-bound raw 5001 management/API port.
WK_PUBLIC_API_URL=https://wemx.cc
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_DATABASE=im_prod
MYSQL_USER=im_prod
MYSQL_PASSWORD=CHANGE_ME_APP
MYSQL_DSN=im_prod:CHANGE_ME_APP@tcp(mysql:3306)/im_prod?charset=utf8mb4&parseTime=true&loc=Local
REDIS_PASSWORD=CHANGE_ME_REDIS
MINIO_ROOT_USER=wukongim
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO
# Verified on 42.194.218.158: April 5, 2026 via `docker pull`.
# Replace this only with another tested immutable image reference.
MINIO_IMAGE=minio/minio@sha256:14cea493d9a34af32f524e538b8346cf79f3321eff8e708c1e2960462bd8936e
MINIO_INTERNAL_URL=http://minio:9000
MINIO_DOWNLOAD_URL=https://wemx.cc/minio
# Keep blank for the current TangSengDaoDaoServerLib/WuKongIM combination.
# Internal API access is constrained by Docker networking plus
# PUBLIC_WK_API_BIND=127.0.0.1:5001.
WK_MANAGER_TOKEN=
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET
WK_CALL_TICKET_SECRET=CHANGE_ME_CALL_TICKET_SECRET
TURN_REALM=wemx.cc
TURN_STATIC_AUTH_SECRET=CHANGE_ME_TURN_SECRET
NGINX_SSL_CERT_PATH=<path-to-nginx-tls-certificate>
NGINX_SSL_KEY_PATH=<path-to-nginx-tls-private-key>
TSDD_MODE=release
TSDD_APP_NAME=WuKongIM
TSDD_ADMIN_PWD=CHANGE_ME_ADMIN
TSDD_SMS_CODE=
TSDD_BASE_URL=https://wemx.cc
TSDD_WEB_LOGIN_URL=https://wemx.cc
NGINX_CLIENT_MAX_BODY_SIZE=100m
BUILD_VERSION=prod-20260405
BUILD_COMMIT=workspace
BUILD_COMMIT_DATE=2026-04-05
BUILD_TREE_STATE=dirty
TURN_TLS_CERT_PATH=<path-to-turn-tls-certificate>
TURN_TLS_PRIVATE_KEY_PATH=<path-to-turn-tls-private-key>
