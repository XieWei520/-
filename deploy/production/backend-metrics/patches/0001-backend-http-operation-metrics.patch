diff --git a/serverlib/pkg/metrics/metrics.go b/serverlib/pkg/metrics/metrics.go
new file mode 100644
index 0000000..f6919a6
--- /dev/null
+++ b/serverlib/pkg/metrics/metrics.go
@@ -0,0 +1,372 @@
+package metrics
+
+import (
+	"bytes"
+	"crypto/subtle"
+	"fmt"
+	"net"
+	"net/http"
+	"sort"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+
+	"github.com/gin-gonic/gin"
+)
+
+const contentType = "text/plain; version=0.0.4; charset=utf-8"
+
+var (
+	httpLatencyBuckets      = []float64{0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1, 2.5, 5, 10}
+	operationLatencyBuckets = []float64{0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1, 2.5, 5, 10, 30}
+)
+
+type Recorder struct {
+	mu               sync.Mutex
+	httpRequests     map[httpLabelKey]uint64
+	httpLatency      map[httpLabelKey]*histogram
+	operationTotal   map[operationLabelKey]uint64
+	operationLatency map[operationLabelKey]*histogram
+}
+
+type httpLabelKey struct {
+	method      string
+	route       string
+	statusClass string
+}
+
+type operationLabelKey struct {
+	operation string
+	result    string
+}
+
+type histogram struct {
+	buckets []float64
+	counts  []uint64
+	sum     float64
+	count   uint64
+}
+
+func NewRecorder() *Recorder {
+	return &Recorder{
+		httpRequests:     make(map[httpLabelKey]uint64),
+		httpLatency:      make(map[httpLabelKey]*histogram),
+		operationTotal:   make(map[operationLabelKey]uint64),
+		operationLatency: make(map[operationLabelKey]*histogram),
+	}
+}
+
+var DefaultRecorder = NewRecorder()
+
+func GinMiddleware() gin.HandlerFunc {
+	return DefaultRecorder.GinMiddleware()
+}
+
+func (r *Recorder) GinMiddleware() gin.HandlerFunc {
+	return func(c *gin.Context) {
+		started := time.Now()
+		c.Next()
+
+		key := httpLabelKey{
+			method:      c.Request.Method,
+			route:       normalizedRoute(c),
+			statusClass: statusClass(c.Writer.Status()),
+		}
+		elapsed := secondsSince(started)
+
+		r.mu.Lock()
+		r.httpRequests[key]++
+		h := r.httpLatency[key]
+		if h == nil {
+			h = newHistogram(httpLatencyBuckets)
+			r.httpLatency[key] = h
+		}
+		h.observe(elapsed)
+		r.mu.Unlock()
+	}
+}
+
+func StartOperation(operation string) func(error) {
+	return DefaultRecorder.StartOperation(operation)
+}
+
+func (r *Recorder) StartOperation(operation string) func(error) {
+	started := time.Now()
+	return func(err error) {
+		r.ObserveOperation(operation, time.Since(started), err)
+	}
+}
+
+func ObserveOperation(operation string, duration time.Duration, err error) {
+	DefaultRecorder.ObserveOperation(operation, duration, err)
+}
+
+func (r *Recorder) ObserveOperation(operation string, duration time.Duration, err error) {
+	result := "success"
+	if err != nil {
+		result = "failure"
+	}
+	key := operationLabelKey{
+		operation: normalizeOperation(operation),
+		result:    result,
+	}
+	elapsed := duration.Seconds()
+	if elapsed < 0 {
+		elapsed = 0
+	}
+
+	r.mu.Lock()
+	r.operationTotal[key]++
+	h := r.operationLatency[key]
+	if h == nil {
+		h = newHistogram(operationLatencyBuckets)
+		r.operationLatency[key] = h
+	}
+	h.observe(elapsed)
+	r.mu.Unlock()
+}
+
+func ProtectedHandler(token string) http.Handler {
+	return DefaultRecorder.ProtectedHandler(token)
+}
+
+func (r *Recorder) ProtectedHandler(token string) http.Handler {
+	return http.HandlerFunc(func(w http.ResponseWriter, req *http.Request) {
+		if !authorized(req, token) {
+			w.WriteHeader(http.StatusUnauthorized)
+			return
+		}
+		w.Header().Set("Content-Type", contentType)
+		_, _ = w.Write([]byte(r.GatherText()))
+	})
+}
+
+func (r *Recorder) GatherText() string {
+	var b bytes.Buffer
+
+	r.mu.Lock()
+	defer r.mu.Unlock()
+
+	writeHelpType(&b, "wukongim_http_requests_total", "HTTP request count by method, normalized route, and status class.", "counter")
+	for _, key := range sortedHTTPKeys(r.httpRequests) {
+		writeMetric(&b, "wukongim_http_requests_total", httpLabels(key, ""), float64(r.httpRequests[key]))
+	}
+
+	writeHelpType(&b, "wukongim_http_request_duration_seconds", "HTTP request latency by method, normalized route, and status class.", "histogram")
+	for _, key := range sortedHTTPHistogramKeys(r.httpLatency) {
+		writeHistogram(&b, "wukongim_http_request_duration_seconds", httpLabels(key, ""), r.httpLatency[key])
+	}
+
+	writeHelpType(&b, "wukongim_operation_total", "Core IM operation count by operation name and result.", "counter")
+	for _, key := range sortedOperationKeys(r.operationTotal) {
+		writeMetric(&b, "wukongim_operation_total", operationLabels(key, ""), float64(r.operationTotal[key]))
+	}
+
+	writeHelpType(&b, "wukongim_operation_duration_seconds", "Core IM operation latency by operation name and result.", "histogram")
+	for _, key := range sortedOperationHistogramKeys(r.operationLatency) {
+		writeHistogram(&b, "wukongim_operation_duration_seconds", operationLabels(key, ""), r.operationLatency[key])
+	}
+
+	return b.String()
+}
+
+func newHistogram(buckets []float64) *histogram {
+	copied := append([]float64(nil), buckets...)
+	return &histogram{
+		buckets: copied,
+		counts:  make([]uint64, len(copied)),
+	}
+}
+
+func (h *histogram) observe(value float64) {
+	if value < 0 {
+		value = 0
+	}
+	for i, bucket := range h.buckets {
+		if value <= bucket {
+			h.counts[i]++
+		}
+	}
+	h.sum += value
+	h.count++
+}
+
+func writeHelpType(b *bytes.Buffer, name, help, typ string) {
+	fmt.Fprintf(b, "# HELP %s %s\n", name, help)
+	fmt.Fprintf(b, "# TYPE %s %s\n", name, typ)
+}
+
+func writeHistogram(b *bytes.Buffer, name string, baseLabels string, h *histogram) {
+	for i, bucket := range h.buckets {
+		writeMetric(b, name+"_bucket", withLeLabel(baseLabels, formatFloat(bucket)), float64(h.counts[i]))
+	}
+	writeMetric(b, name+"_bucket", withLeLabel(baseLabels, "+Inf"), float64(h.count))
+	writeMetric(b, name+"_sum", baseLabels, h.sum)
+	writeMetric(b, name+"_count", baseLabels, float64(h.count))
+}
+
+func writeMetric(b *bytes.Buffer, name, labels string, value float64) {
+	if labels == "" {
+		fmt.Fprintf(b, "%s %s\n", name, formatFloat(value))
+		return
+	}
+	fmt.Fprintf(b, "%s{%s} %s\n", name, labels, formatFloat(value))
+}
+
+func httpLabels(key httpLabelKey, extra string) string {
+	labels := fmt.Sprintf(`method="%s",route="%s",status_class="%s"`,
+		escapeLabelValue(key.method),
+		escapeLabelValue(key.route),
+		escapeLabelValue(key.statusClass),
+	)
+	if extra == "" {
+		return labels
+	}
+	return labels + "," + extra
+}
+
+func operationLabels(key operationLabelKey, extra string) string {
+	labels := fmt.Sprintf(`operation="%s",result="%s"`,
+		escapeLabelValue(key.operation),
+		escapeLabelValue(key.result),
+	)
+	if extra == "" {
+		return labels
+	}
+	return labels + "," + extra
+}
+
+func withLeLabel(labels, le string) string {
+	return labels + `,le="` + escapeLabelValue(le) + `"`
+}
+
+func escapeLabelValue(value string) string {
+	value = strings.ReplaceAll(value, `\`, `\\`)
+	value = strings.ReplaceAll(value, "\n", `\n`)
+	value = strings.ReplaceAll(value, `"`, `\"`)
+	return value
+}
+
+func formatFloat(value float64) string {
+	return strconv.FormatFloat(value, 'g', -1, 64)
+}
+
+func sortedHTTPKeys(values map[httpLabelKey]uint64) []httpLabelKey {
+	keys := make([]httpLabelKey, 0, len(values))
+	for key := range values {
+		keys = append(keys, key)
+	}
+	sort.Slice(keys, func(i, j int) bool { return lessHTTPKey(keys[i], keys[j]) })
+	return keys
+}
+
+func sortedHTTPHistogramKeys(values map[httpLabelKey]*histogram) []httpLabelKey {
+	keys := make([]httpLabelKey, 0, len(values))
+	for key := range values {
+		keys = append(keys, key)
+	}
+	sort.Slice(keys, func(i, j int) bool { return lessHTTPKey(keys[i], keys[j]) })
+	return keys
+}
+
+func lessHTTPKey(left, right httpLabelKey) bool {
+	if left.method != right.method {
+		return left.method < right.method
+	}
+	if left.route != right.route {
+		return left.route < right.route
+	}
+	return left.statusClass < right.statusClass
+}
+
+func sortedOperationKeys(values map[operationLabelKey]uint64) []operationLabelKey {
+	keys := make([]operationLabelKey, 0, len(values))
+	for key := range values {
+		keys = append(keys, key)
+	}
+	sort.Slice(keys, func(i, j int) bool { return lessOperationKey(keys[i], keys[j]) })
+	return keys
+}
+
+func sortedOperationHistogramKeys(values map[operationLabelKey]*histogram) []operationLabelKey {
+	keys := make([]operationLabelKey, 0, len(values))
+	for key := range values {
+		keys = append(keys, key)
+	}
+	sort.Slice(keys, func(i, j int) bool { return lessOperationKey(keys[i], keys[j]) })
+	return keys
+}
+
+func lessOperationKey(left, right operationLabelKey) bool {
+	if left.operation != right.operation {
+		return left.operation < right.operation
+	}
+	return left.result < right.result
+}
+
+func normalizedRoute(c *gin.Context) string {
+	route := strings.TrimSpace(c.FullPath())
+	if route == "" {
+		return "unknown"
+	}
+	return route
+}
+
+func statusClass(status int) string {
+	if status <= 0 {
+		status = http.StatusOK
+	}
+
+	switch {
+	case status < 200:
+		return "1xx"
+	case status < 300:
+		return "2xx"
+	case status < 400:
+		return "3xx"
+	case status < 500:
+		return "4xx"
+	default:
+		return "5xx"
+	}
+}
+
+func normalizeOperation(operation string) string {
+	operation = strings.TrimSpace(strings.ToLower(operation))
+	if operation == "" {
+		return "unknown"
+	}
+	return operation
+}
+
+func secondsSince(started time.Time) float64 {
+	elapsed := time.Since(started).Seconds()
+	if elapsed < 0 {
+		return 0
+	}
+	return elapsed
+}
+
+func authorized(req *http.Request, token string) bool {
+	if token == "" {
+		return isLoopbackRemote(req.RemoteAddr)
+	}
+
+	header := req.Header.Get("Authorization")
+	const prefix = "Bearer "
+	if !strings.HasPrefix(header, prefix) {
+		return false
+	}
+	got := strings.TrimPrefix(header, prefix)
+	return subtle.ConstantTimeCompare([]byte(got), []byte(token)) == 1
+}
+
+func isLoopbackRemote(remoteAddr string) bool {
+	host, _, err := net.SplitHostPort(remoteAddr)
+	if err != nil {
+		host = remoteAddr
+	}
+	ip := net.ParseIP(strings.TrimSpace(host))
+	return ip != nil && ip.IsLoopback()
+}
