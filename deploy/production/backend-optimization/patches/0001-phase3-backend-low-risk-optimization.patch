+	userIMRouteCache.RLock()
+	entry, ok := userIMRouteCache.entries[key]
+	userIMRouteCache.RUnlock()
+	if !ok {
+		return userIMRouteCacheEntry{}, false
+	}
+	if now.Before(entry.expiresAt) {
+		return entry, true
+	}
