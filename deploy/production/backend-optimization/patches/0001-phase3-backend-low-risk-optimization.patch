+func (sm *ServiceMinio) uploadClient(uploadURL *url.URL) (minioClient, error) {
+	sm.minioMu.Lock()
+	defer sm.minioMu.Unlock()
+
+	if sm.minioClient != nil {
+		return sm.minioClient, nil
+	}
+	if sm.clientFactory == nil {
+		sm.clientFactory = defaultMinioClientFactory
+	}
+	client, err := sm.clientFactory(uploadURL.Host, &minio.Options{
+		Creds:  credentials.NewStaticV4(sm.ctx.GetConfig().Minio.AccessKeyID, sm.ctx.GetConfig().Minio.SecretAccessKey, ""),
+		Secure: strings.HasPrefix(uploadURL.Scheme, "https"),
+	})
+	if err != nil {
+		return nil, err
+	}
+	sm.minioClient = client
+	if sm.readyBuckets == nil {
+		sm.readyBuckets = map[string]struct{}{}
+	}
+	return client, nil
+}
+
+func (sm *ServiceMinio) ensureBucketReady(ctx context.Context, client minioClient, bucketName string) error {
+	sm.minioMu.Lock()
+	defer sm.minioMu.Unlock()
+
+	if sm.readyBuckets == nil {
+		sm.readyBuckets = map[string]struct{}{}
+	}
+	if _, ok := sm.readyBuckets[bucketName]; ok {
+		return nil
+	}
+
+	started := time.Now()
+	exists, err := client.BucketExists(ctx, bucketName)
+	metrics.ObserveStorageOperation("minio", "bucket_exists", time.Since(started), err)
+	if err != nil {
+		sm.Error(fmt.Sprintf("check %s bucket exists failed", bucketName), zap.Error(err))
+		return err
+	}
+	if !exists {
+		started = time.Now()
+		err = client.MakeBucket(ctx, bucketName, minio.MakeBucketOptions{})
+		metrics.ObserveStorageOperation("minio", "bucket_create", time.Since(started), err)
+		if err != nil {
+			sm.Error(fmt.Sprintf("create %s bucket failed", bucketName), zap.Error(err))
+			return err
+		}
+		started = time.Now()
+		err = client.SetBucketPolicy(ctx, bucketName, minioPublicReadBucketPolicy(bucketName))
+		metrics.ObserveStorageOperation("minio", "bucket_policy_set", time.Since(started), err)
+		if err != nil {
+			sm.Error("set minio bucket policy failed", zap.Error(err))
+			return err
+		}
+	}
+	sm.readyBuckets[bucketName] = struct{}{}
+	return nil
+}
+
 func (sm *ServiceMinio) DownloadURL(ph string, filename string) (string, error) {
 	minioConfig := sm.ctx.GetConfig().Minio
 	return minioDownloadURL(minioConfig.DownloadURL, ph, filename)
