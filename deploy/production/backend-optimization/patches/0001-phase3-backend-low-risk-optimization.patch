+func TestUserIM_DoesNotCacheNon2xxOrMalformedJSON(t *testing.T) {
+	tests := []struct {
+		name       string
+		statusCode int
+		body       string
+	}{
+		{
+			name:       "non 2xx",
+			statusCode: http.StatusBadGateway,
+			body:       `{"error":"bad gateway"}`,
+		},
+		{
+			name:       "malformed json",
+			statusCode: http.StatusOK,
+			body:       `{`,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			cfg := config.New()
+			ctx := config.NewContext(cfg)
+			httpRouter := wkhttp.New()
+			u := &User{ctx: ctx}
+			httpRouter.GET("/v1/users/:uid/im", u.userIM)
+
+			var hits int32
+			upstream := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+				hit := atomic.AddInt32(&hits, 1)
+				w.Header().Set("Content-Type", "application/json")
+				if hit == 1 {
+					w.WriteHeader(tt.statusCode)
+					_, _ = w.Write([]byte(tt.body))
+					return
+				}
+				_, _ = w.Write([]byte(`{"tcp_addr":"wemx.cc:5100","ws_addr":"ws://wemx.cc:5200","wss_addr":"wss://wemx.cc/ws"}`))
+			}))
+			defer upstream.Close()
+
+			ctx.GetConfig().WuKongIM.APIURL = upstream.URL
+			ctx.GetConfig().WuKongIM.ManagerToken = "test-token"
+
+			w := httptest.NewRecorder()
+			req := httptest.NewRequest(http.MethodGet, "/v1/users/route-user-1/im", nil)
+			httpRouter.ServeHTTP(w, req)
+			require.NotEqual(t, http.StatusOK, w.Code, w.Body.String())
+
+			w = httptest.NewRecorder()
+			req = httptest.NewRequest(http.MethodGet, "/v1/users/route-user-1/im", nil)
+			httpRouter.ServeHTTP(w, req)
+			require.Equal(t, http.StatusOK, w.Code, w.Body.String())
+			assert.JSONEq(t, `{"tcp_addr":"wemx.cc:5100","ws_addr":"ws://wemx.cc:5200","wss_addr":"wss://wemx.cc/ws","preferred_transport":"wss","preferred_addr":"wss://wemx.cc/ws"}`, w.Body.String())
+			assert.Equal(t, int32(2), atomic.LoadInt32(&hits))
+		})
+	}
+}
